# PostgreSQL connection string.
# Free option: create a project at https://neon.tech and paste its string here.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Port the API listens on (optional; defaults to 3000).
PORT=3000

# Telegram alerts (wired up in a later phase — leave empty for now).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
